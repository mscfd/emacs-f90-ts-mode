Name: use statement 1
=-=
module foo
 use mod1
 use mod2, only: sub1, &
        sub2
 use mod3, &
        mod4
 ! another
 mod5, only: baz1,&
           baz2

contains
 subroutine sub_bar()
      use mod3, only: fun1 => mod3_fun1, &
             fun2 => mod3_fun2, &
             ! one more
             fun3 => mod3_fun3
 end subroutine sub_bar
end module foo
