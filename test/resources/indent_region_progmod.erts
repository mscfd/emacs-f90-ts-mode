Name: program 2
=-=
program program2
 implicit none
 integer :: i
 do i = 1,10
      print *,'i = ', i
 end do
end program program2
=-=-=

Name: program 3
=-=
program program3
 implicit none (type, external)
 integer :: i
 do i = 1,10
      call sub(i)
 end do
contains
 subroutine sub(k)
      integer, intent(in) :: k
      print *,k
 end subroutine sub
end program program3
