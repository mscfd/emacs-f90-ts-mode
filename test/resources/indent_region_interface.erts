Name: generic interface
=-=
module symmetric33

 interface symmul
      ! all matrices assumed to be symmetric
      module procedure symmul_mat33_mat33
      module procedure symmul_sym6_mat33
      module procedure symmul_mat33_sym6
      ! module procedure symmul_sym6_sym6
 end interface symmul

 interface operator(.symmul.)
      module procedure symmul_sym6_sym6
 end interface operator(.symmul.)

contains
 ! implementation
end module symmetric33
=-=-=


Name: abstract interface
=-=
module mod
 abstract interface
      impure function predicate_ifc(self, &
                                    k1, k2, &
                                    x1, x2) &
             result(flag)
           import some_t, other_t, &
                  key_t
           logical :: flag
           class(some_t), intent(in) :: self
           class(key_t),  intent(in) :: k1, &
                                        k2
           class(*),      intent(in) :: x1
           type(other_t), intent(in) :: x2
      end function predicate_ifc
 end interface
end module mod
