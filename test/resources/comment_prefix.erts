Point-Char: |

Code:
  (lambda ()
    (f90-ts-mode)
    (f90-ts-mode-test--mark-region-modify #'f90-ts-mark-region-enlarge))

Name: comment prefix 1
=-=
subroutine sub()
   i = 6
   !!$ comment 1
   !!$ comment 2
   @!!$ comment 3|
   !!$ comment 4
   j = 5
end subroutine sub
=-=
subroutine sub()
   i = 6
   @!!$ comment 1
   !!$ comment 2
   !!$ comment 3
   !!$ comment 4|
   j = 5
end subroutine sub
=-=-=

Name: comment prefix 2
=-=
subroutine sub()
   i = 6
   ! match simple comment prefix
   !!$ comment 1
   ! comment 2
   @! comment 3|
   !!$ comment 4
   j = 5
end subroutine sub
=-=
subroutine sub()
   i = 6
   ! match simple comment prefix
   !!$ comment 1
   @! comment 2
   ! comment 3|
   !!$ comment 4
   j = 5
end subroutine sub
=-=-=

