Name: preproc6
=-=
subroutine sub()
     block
#if defined(__SOME_COMPILER) || defined(__OTHER_COMPILER)
          x = 1
#elif __EXTRA_COMPILER && (__VERSION__ >= 123)
          x = 2
#else
          x = 3
#endif
     end block
end subroutine sub
