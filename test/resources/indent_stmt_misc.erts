Name: leading ampersand with indent 1
=-=
module mod
contains
subroutine simulate(set, fsim1, &
fsim2, out)
real(kind=real32), dimension(:), &
target, &

intent(in) :: set
integer, dimension(:), &
allocatable, &
intent(out) :: fsim1, &
fsim2

procedure(simulator_ifc) :: &
fsim

call sim_init(set, &
out)
run: if (condition) then
call sim_run_1(fsim, set, &
out)
else
call sim_run_2(fsim, set, &
out)
end
end|
end
=-=
module mod
contains
 subroutine simulate(set, fsim1, &
    &                fsim2, out)
      real(kind=real32), dimension(:), &
         &               target, &

         &               intent(in) :: set
      integer, dimension(:), &
         &     allocatable, &
         &     intent(out) :: fsim1, &
         &                    fsim2

      procedure(simulator_ifc) :: &
         &                        fsim

      call sim_init(set, &
         &          out)
      run: if (condition) then
           call sim_run_1(fsim, set, &
              &           out)
      else
           call sim_run_2(fsim, set, &
              &           out)
      end if run
 end subroutine simulate|
end
