Name: stmt unchanged-modified 2
=-=
! ampersand are removed and reinsert, so buffer is temporarily modified
subroutine sub()
     call foo(x1, &
       &     x2, &
        &     x4, &
        &     x5)|
end subroutine sub
=-=
