module mod
contains
      subroutine sub()
           read(file_unit, 1, err=200) x, y, z
           return
    1      format(3F12.5)
  200      print 30000, "error"
           error stop
 3000      format(2x,a10)
30000      format(2x,a10)
      end subroutine sub
end module mod
