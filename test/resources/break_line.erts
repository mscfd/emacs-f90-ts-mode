Name: break openmp 1
=-=
subroutine sub_1()
!$omp parallel do| schedule(static)
     do i = 1,10
        call sub_2(i)
     end do
!$omp end parallel
end subroutine sub_1
=-=
subroutine sub_1()
!$omp parallel do &
!$omp |schedule(static)
     do i = 1,10
        call sub_2(i)
     end do
!$omp end parallel
end subroutine sub_1
