Name: align array literal 3
=-=
subroutine arr3()
     type(some_t), dimension(1:3) :: &
            arr = [some_t(val=1, x=5.0), some_t(val=1, x=7.0), &
                   some_t(), &
                   some_t(x=-2.0), &
                                         some_t(val=2, x=7.0) &
                     ]
end subroutine arr3
