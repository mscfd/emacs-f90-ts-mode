Name: align argument lists 6
=-=
function eval() result(w)
     call algorithm(fun1(a, b), fun2(x, y, &
              z &
                                   ), &
                            fun3(u, &
            v, &
              w))
end
=-=
function eval() result(w)
     call algorithm(fun1(a, b), fun2(x, y, &
                                     z &
                                       ), &
                    fun3(u, &
                         v, &
                         w))
end function eval
