Name: align array literal 5
=-=
subroutine arr5()
     character(len=5), dimension(1:3) :: & ! comment
          
          ! comment
          
                                  rgb = &
                                         (/ &
              'red  ', &
              'green', &
              'blue ' /), &
           alpha = 'trnsp'
end
=-=
subroutine arr5()
     character(len=5), dimension(1:3) :: & ! comment
          
                                         ! comment
          
                                         rgb = &
                                         (/ &
                                           'red  ', &
                                           'green', &
                                           'blue ' /), &
                                         alpha = 'trnsp'
end subroutine arr5
