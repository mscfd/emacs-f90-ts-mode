Name: align array literal 1
=-=
subroutine arr1()
     ! list context alignment of numbers in array
     integer, dimension(1:3,1:4), parameter:: &
            facet_ix = reshape(&
                               [2,3,4, &
                                1,4,3, &
                                1,2,4, &
                                1,3,2 &
                                  ], [3,4])
end subroutine arr1
=-=-=

Name: align array literal 2
=-=
subroutine arr2()
     real, dimension(1:10), parameter :: &
            bernoulli = (/ 1.0, -0.5, 0.16667, 0.0, &
                          -0.03333, 0.0, &
                           0.0238, 0.0 &
                            /)
end subroutine arr2
