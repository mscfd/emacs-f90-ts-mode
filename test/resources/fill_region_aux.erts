Name: fill all break 7
=-=
subroutine code()
     check_break_at_40 = a+b+c+d+e+f+g
     check_break_at_40 = a1+b+c+d+e+f+g
     check_break_at_40 = a12+b+c+d+e+f+g
     check_break_at_40 = a123+b+c+d+e+f+g
     check_break_at_40 = a1234+b+c+d+e+f+g
end subroutine code
=-=
subroutine code()
     check_break_at_40 = a+b+c+d+e+f+g
     check_break_at_40 = a1+b+c+d+e+f+g
     check_break_at_40 = a12+b+c+d+e+f+g
     check_break_at_40 = a123+b+c+d+e+ &
                         f+g
     check_break_at_40 = a1234+b+c+d+e &
                              +f+g
end subroutine code
