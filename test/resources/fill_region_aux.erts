Name: fill all break 6
=-=
! do break before or after "%" if not possible otherwise
subroutine sub()
     call some_value_0123456789%method_name()
     call some_value_01234567890123456%method_name()
end subroutine sub
=-=
! do break before or after "%" if not
! possible otherwise
subroutine sub()
     call some_value_0123456789% &
            method_name()
     call some_value_01234567890123456 &
            %method_name()
end subroutine sub
