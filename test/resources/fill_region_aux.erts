Name: fill all break 2
=-=
! do not break before comma (breaking after arg4 and before comma would be possible)
subroutine sub_1()
     call sub_2(arg1, arg2, arg3, arg4, arg5, arg6, arg7, arg8, arg9, argA, argB, argC, argD, argE, argF)
end subroutine sub_1
=-=
! do not break before comma (breaking
! after arg4 and before comma would be
! possible)
subroutine sub_1()
     call sub_2(arg1, arg2, arg3, &
                arg4, arg5, arg6, &
                arg7, arg8, arg9, &
                argA, argB, argC, &
                argD, argE, argF)
end subroutine sub_1
=-=-=

Name: fill all break 3
=-=
! do not break before opening parenthesis
subroutine sub()
     very_long_name = long_fun_name39(arg1, arg2, arg3)
     very_long_name = long_fun_name_40(arg1, arg2, arg3)
end subroutine sub
=-=
! do not break before opening
! parenthesis
subroutine sub()
     very_long_name = long_fun_name39( &
            arg1, arg2, arg3)
     very_long_name = &
            long_fun_name_40(arg1, &
                             arg2, arg3)
end subroutine sub
=-=-=

Name: fill all break 4
=-=
!1 do not break after "call", there is no gain
!2 do break before parenthesis, as no other reasonable break point is available
subroutine sub()
     call very_long_name_till_column40(arg1, arg2, arg3, arg4, arg5, arg6, arg7, arg8, arg9, argA, argB, argC, argD, argE, argF)
end subroutine sub
=-=
!1 do not break after "call", there is
!1 no gain
!2 do break before parenthesis, as no
!2 other reasonable break point is
!2 available
subroutine sub()
     call very_long_name_till_column40 &
            (arg1, arg2, arg3, arg4, &
             arg5, arg6, arg7, arg8, &
             arg9, argA, argB, argC, &
             argD, argE, argF)
end subroutine sub
=-=-=

Name: fill all break 5
=-=
!1 do not break before or after "%"
subroutine sub()
     some_val%xyz0123 = other_val%xyz0123
end subroutine sub
=-=
!1 do not break before or after "%"
subroutine sub()
     some_val%xyz0123 = &
            other_val%xyz0123
end subroutine sub
