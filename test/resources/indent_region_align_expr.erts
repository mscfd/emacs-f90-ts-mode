Name: align logical expression 1
=-=
subroutine sub1()
     do while (A1 .and. A2 .and. A3 .and. A4 &
                  .and. B1)
     end do
     do while (A1 .and. A2 .and. A3 .and. A4 &
                           .and. B1)
     end do
     do while (A1 .and. A2 .and. A3 .and. A4 &
                                    .and. B1)
     end do
end subroutine sub1
