Name: align logical expression 7
=-=
subroutine sub7()
     if (A1 .and. A2 .and. (A3 .or. A4) .and. &
          B1 &
                       .and. C1 .and. C2 &
                     .eqv. D1 .and. D2 &
                               .or. D1 .and. D2 .and. &
                         E1) then
     end if
end subroutine sub7
=-=
subroutine sub7()
     if (A1 .and. A2 .and. (A3 .or. A4) .and. &
         B1 &
            .and. C1 .and. C2 &
                     .eqv. D1 .and. D2 &
            .or. D1 .and. D2 .and. &
         E1) then
     end if
end subroutine sub7
