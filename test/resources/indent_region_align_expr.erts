Name: align logical expression 8
=-=
subroutine sub8()
   f =     condition1(p1, &
                      p2) &
       .or. condition2(q1, q2, &
                               q3) &
           .and. (  condition3(a1,a2,a3&
                            )&
                  .or. condition4(&
                                 fun1(x,y), &
                                  fun2(u,v)) &
.eqv. condition5(&
              fun1(x,y), &
             fun2(u,v)) &
                           )&
.neqv. condition6(&
               fun1(x,y), &
               fun2(u,v) &
)
end subroutine sub8
=-=
subroutine sub8()
     f =     condition1(p1, &
                        p2) &
        .or. condition2(q1, q2, &
                        q3) &
        .and. (  condition3(a1,a2,a3&
                           )&
               .or. condition4(&
                               fun1(x,y), &
                               fun2(u,v)) &
               .eqv. condition5(&
                                fun1(x,y), &
                                fun2(u,v)) &
              )&
        .neqv. condition6(&
                          fun1(x,y), &
                          fun2(u,v) &
                         )
end subroutine sub8
