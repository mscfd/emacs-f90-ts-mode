Name: align logical expression 9
=-=
subroutine sub()
     ! check that column one right to '(' and '=' is taken
     if (     condition1(x) &
         .or. condition2(x)) then
          flag_has_property =     cond1 .or. cond2 &
                             .or. cond2
          call sub(      flag1 &
                   .and. flag2)
     end if
end subroutine sub
