Name: align logical expression 6
=-=
subroutine sub6()
     if (A1 .and. A2 .and. (A3 .or. A4) .and. &
         B3 .and. B4 .and. &
         (C1 .or. C2)) then
     end if

     if (A1 .and. A2 .and. (A3 .or. A4) .and. &
                  B3 .and. B4 .and. &
                           (C1 .or. C2)) then
     end if

     if (A1 .and. A2 .and. (A3 .or. A4) .and. &
                           B3 .and. B4 .and. &
                  (C1 .or. C2)) then
     end if
end subroutine sub6
