Name: align logical expression 3
=-=
subroutine sub3()
     do while (A1 .and. (A2 .and. A3) .and. A4 &
                  .and. (B1 == B2) &
                  .or. C1)
     end do
     do while (A1 .and. (A2 .and. A3) .and. A4 &
                  .and. (B1 == B2) &
                                      .or. C1)
     end do
end subroutine sub3
